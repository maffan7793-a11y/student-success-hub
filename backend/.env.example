# Flask
FLASK_ENV=production
SECRET_KEY=change-this-to-a-random-secret
JWT_SECRET_KEY=change-this-to-a-different-random-secret

# Database (Render Postgres connection string)
DATABASE_URL=postgresql://user:password@host:5432/student_success_hub

# Frontend URL (for CORS + email links)
FRONTEND_URL=https://your-frontend.onrender.com

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
INTERNSHIP_FEE_PAISE=7900

# Email (SMTP - e.g. Gmail App Password, SendGrid, etc.)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@studentsuccesshub.com

# Admin bootstrap (used once by seed script)
ADMIN_EMAIL=admin@studentsuccesshub.com
ADMIN_PASSWORD=change-this-admin-password
